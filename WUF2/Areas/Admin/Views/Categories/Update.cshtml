@model WUF2.Models.Categories

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Kateqoriyanı Yenilə</h4>
                </div>
                <div class="card-body">
                    <form asp-area="Admin" asp-controller="Categories" asp-action="Update" method="post">
                        <!-- ID mütləq gizli input olaraq göndərilməlidir -->
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Kateqoriya Adı</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Dəyişiklikləri Saxla</button>
                            <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-secondary">Ləğv Et</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
