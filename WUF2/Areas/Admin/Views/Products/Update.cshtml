@model WUF2.Models.Products

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Məhsulu Yenilə</h4>
                </div>
                <div class="card-body">
                    <form asp-area="Admin" asp-controller="Products" asp-action="Update" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Məhsul Adı</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label">Qiyməti</label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CategoriesId" class="form-label">Kateqoriya</label>
                            <select asp-for="CategoriesId" class="form-control">
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var cat in ViewBag.Categories as List<WUF2.Models.Categories>)
                                    {
                                        if (cat.Id == Model.CategoriesId)
                                        {
                                            <option value="@cat.Id" selected="selected">@cat.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@cat.Id">@cat.Name</option>
                                        }
                                    }
                                }
                            </select>
                            <span asp-validation-for="CategoriesId" class="text-danger"></span>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Dəyişiklikləri Saxla</button>
                            <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-secondary">Ləğv Et</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
