@model WUF2.Models.Products

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Yeni Məhsul</h4>
                </div>
                <div class="card-body">
                    <form asp-area="Admin" asp-controller="Products" asp-action="Create" method="post">
                        
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Məhsul Adı</label>
                            <input asp-for="Name" class="form-control" placeholder="Məsələn: iPhone 15" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label">Qiyməti</label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Məsələn: 2500" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CategoriesId" class="form-label">Kateqoriya Seçin</label>
                            <select asp-for="CategoriesId" class="form-control">
                                <option value="">-- Bir kateqoriya seçin --</option>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var cat in ViewBag.Categories as List<WUF2.Models.Categories>)
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="CategoriesId" class="text-danger"></span>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Yadda Saxla</button>
                            <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-secondary">Ləğv Et</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
